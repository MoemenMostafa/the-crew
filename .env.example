# The Crew — Slack tokens (one app per persona; create them in the "loquina" workspace).
# Copy this file to .env and fill in real values. .env is gitignored.
#
# For each persona's Slack app (api.slack.com/apps):
#   - Enable Socket Mode  -> generates an App-Level token (xapp-...) with scope connections:write
#   - Bot Token Scopes    -> app_mentions:read, chat:write, channels:history, im:history, im:read, im:write
#   - Event Subscriptions  -> message.channels, message.im, app_mention
#   - Install to workspace -> Bot User OAuth token (xoxb-...)
#   - Invite the bot to its channel(s).

# Adam — Senior Developer (Phase 1)
ADAM_SLACK_BOT_TOKEN=xoxb-...
ADAM_SLACK_APP_TOKEN=xapp-...

# Eva — Customer Support (Phase 2)
EVA_SLACK_BOT_TOKEN=xoxb-...
EVA_SLACK_APP_TOKEN=xapp-...

# Zakarya — Product Owner (Phase 2)
ZAKARYA_SLACK_BOT_TOKEN=xoxb-...
ZAKARYA_SLACK_APP_TOKEN=xapp-...

# Sara — Designer (Phase 2)
SARA_SLACK_BOT_TOKEN=xoxb-...
SARA_SLACK_APP_TOKEN=xapp-...
